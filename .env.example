# PostgreSQL Database connection URL
# Format: postgresql://username:password@hostname:port/database_name
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/smartnest

# JWT Secret Key for user authorization tokens
# Can be generated using: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_a_secure_random_32_character_hex_key

# MQTT Broker connection configuration (e.g. EMQX)
MQTT_BROKER_URL=broker.emqx.io
MQTT_PORT=1883
